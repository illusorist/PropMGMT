{
  "BootstrapAdmin": {
    "Enabled": false,
    "Username": "",
    "Password": ""
  },
  "PropertyImageUpload": {
    "RootPath": "uploads/properties",
    "PublicBasePath": "/uploads/properties",
    "MaxSizeBytes": 10485760,
    "AllowedExtensions": [ ".jpg", ".jpeg", ".png", ".webp" ],
    "AllowedMimeTypes": [ "image/jpeg", "image/png", "image/webp" ]
  },
  "LeadImageUpload": {
    "RootPath": "uploads/leads",
    "MaxSizeBytes": 10485760,
    "AllowedExtensions": [ ".jpg", ".jpeg", ".png", ".webp" ],
    "AllowedMimeTypes": [ "image/jpeg", "image/png", "image/webp" ]
  },
  "Integrations": {
    "Requests": {
      "Enabled": true,
      "HeaderName": "X-API-Key",
      "ApiKey": "CHANGE_ME_REQUESTS_INGESTION_KEY"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
